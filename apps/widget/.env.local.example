# ==========================================
# APPS/WIDGET (Widget Runtime)
# ==========================================
# URL project Convex Anda (didapatkan setelah install/init Convex)
NEXT_PUBLIC_CONVEX_URL=https://<nama-project>.convex.cloud

# Catatan:
# Widget URL tidak perlu env terpisah untuk apps/embed.
# Embed loader akan mengikuti origin dari script widget.js secara otomatis.
