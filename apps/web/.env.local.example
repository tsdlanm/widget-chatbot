# ==========================================
# APPS/WEB (Dashboard)
# ==========================================
# Kredensial autentikasi dari Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Rute bawaan Clerk
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Email admin yang diizinkan masuk ke Dashboard (pisahkan dengan koma)
ALLOWED_EMAILS=admin1@domain.com,admin2@domain.com

# URL project Convex Anda (didapatkan setelah install/init Convex)
NEXT_PUBLIC_CONVEX_URL=https://<nama-project>.convex.cloud

# URL host widget.js untuk preview/embed snippet di dashboard
NEXT_PUBLIC_WIDGET_URL=http://localhost:3001
